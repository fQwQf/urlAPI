FROM --platform=linux/arm64 node:22-alpine AS builder

WORKDIR /app

COPY static/package.json static/package-lock.json ./
RUN npm ci

COPY static/ .
RUN npm run build

FROM --platform=linux/arm64 nginx:stable-alpine

RUN rm /etc/nginx/conf.d/default.conf

COPY static/nginx.conf.template /etc/nginx/templates/default.conf.template
COPY static/entrypoint.sh /docker-entrypoint-custom.sh
RUN chmod +x /docker-entrypoint-custom.sh

COPY --from=builder /app/dist /usr/share/nginx/html

ENV BACKEND_URL=http://localhost:2233

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint-custom.sh"]
