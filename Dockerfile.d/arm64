FROM golang:1.26.2-alpine AS builder
WORKDIR /app
RUN apk add --no-cache gcc musl-dev

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ENV CGO_ENABLED=1 GOOS=linux GOARCH=arm64

RUN go build -o urlAPI .

FROM alpine:3.23
WORKDIR /app

RUN apk add --no-cache ca-certificates

COPY --from=builder /app/urlAPI .
EXPOSE 2233
CMD ["./urlAPI"]
